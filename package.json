{
  "name": "circuit-lens",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @circuit-lens/web",
    "build": "npm run build --workspace @circuit-lens/web",
    "lint": "npm run lint --workspace @circuit-lens/web",
    "typecheck": "npm run typecheck --workspace @circuit-lens/web",
    "test:engine": "python -m pytest packages/engine/tests"
  },
  "engines": {
    "node": ">=22"
  }
}
